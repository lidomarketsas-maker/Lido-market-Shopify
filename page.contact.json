{
  "sections": {
    "main": {
      "type": "custom-liquid",
      "settings": {
        "liquid": "<div class=\"lido-contact-page\">\n  <div class=\"lido-contact-page__grid\">\n\n    <!-- COLONNA SINISTRA: FORM -->\n    <div class=\"lido-contact-page__form-col\">\n      <p class=\"lido-brand-story__tag\">Scrivici</p>\n      <h1 class=\"lido-contact-page__title\">Contattaci</h1>\n      <p class=\"lido-contact-page__sub\">Per informazioni su prodotti, ordini all'ingrosso o per diventare rivenditore autorizzato. Risponderemo entro 24 ore lavorative.</p>\n      {%- form 'contact', id: 'ContactForm' -%}\n        {%- if form.posted_successfully? -%}\n          <div style=\"background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:16px 20px;margin-bottom:24px;font-family:'Urbanist',sans-serif;font-size:0.92rem;color:#166534;\">\n            Messaggio inviato! Ti risponderemo entro 24 ore lavorative.\n          </div>\n        {%- endif -%}\n        <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;\">\n          <div class=\"field\">\n            <input class=\"field__input\" autocomplete=\"name\" type=\"text\" id=\"ContactForm-name\" name=\"contact[{{ 'contact.form.name' | t }}]\" value=\"{%- if form.name -%}{{ form.name }}{%- elsif customer -%}{{ customer.name }}{%- endif -%}\" placeholder=\"Nome e cognome\">\n            <label class=\"field__label\" for=\"ContactForm-name\">Nome *</label>\n          </div>\n          <div class=\"field\">\n            <input class=\"field__input\" autocomplete=\"tel\" type=\"tel\" id=\"ContactForm-phone\" name=\"contact[Telefono]\" value=\"\" placeholder=\"+39 000 000 0000\">\n            <label class=\"field__label\" for=\"ContactForm-phone\">Telefono</label>\n          </div>\n        </div>\n        <div class=\"field\" style=\"margin-bottom:16px;\">\n          <input class=\"field__input\" autocomplete=\"email\" type=\"email\" id=\"ContactForm-email\" name=\"contact[email]\" autocorrect=\"off\" autocapitalize=\"off\" value=\"{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}\" placeholder=\"email@azienda.it\">\n          <label class=\"field__label\" for=\"ContactForm-email\">Email *</label>\n          {%- if form.errors contains 'email' -%}\n            <p style=\"color:#dc2626;font-size:0.8rem;\">Inserisci un indirizzo email valido.</p>\n          {%- endif -%}\n        </div>\n        <div class=\"field\" style=\"margin-bottom:16px;\">\n          <input class=\"field__input\" type=\"text\" id=\"ContactForm-company\" name=\"contact[Azienda]\" value=\"\" placeholder=\"Ragione sociale\">\n          <label class=\"field__label\" for=\"ContactForm-company\">Azienda</label>\n        </div>\n        <div class=\"field\" style=\"margin-bottom:24px;\">\n          <textarea class=\"field__input\" rows=\"6\" id=\"ContactForm-body\" name=\"contact[body]\" placeholder=\"Descrivi la tua richiesta: prodotti di interesse, quantitativi, mercato di riferimento...\">{%- if form.body -%}{{ form.body }}{%- endif -%}</textarea>\n          <label class=\"field__label\" for=\"ContactForm-body\">Messaggio *</label>\n        </div>\n        <button type=\"submit\" class=\"button button--primary\" style=\"width:100%;height:52px;font-size:0.88rem;letter-spacing:0.1em;\">\n          Invia messaggio\n        </button>\n      {%- endform -%}\n    </div>\n\n    <!-- COLONNA DESTRA: INFO CONTATTO -->\n    <div>\n      <div class=\"lido-contact-info__block\">\n        <p class=\"lido-contact-info__title\">Informazioni di contatto</p>\n\n        <div class=\"lido-contact-info__row\">\n          <div class=\"lido-contact-info__icon\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z\"/></svg>\n          </div>\n          <div>\n            <div class=\"lido-contact-info__label\">Email</div>\n            <div class=\"lido-contact-info__value\"><a href=\"mailto:lidomarketsas@gmail.com\">lidomarketsas@gmail.com</a></div>\n          </div>\n        </div>\n\n        <div class=\"lido-contact-info__row\">\n          <div class=\"lido-contact-info__icon\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z\"/></svg>\n          </div>\n          <div>\n            <div class=\"lido-contact-info__label\">WhatsApp</div>\n            <div class=\"lido-contact-info__value\"><a href=\"https://wa.me/39\" target=\"_blank\">Scrivici su WhatsApp</a></div>\n          </div>\n        </div>\n\n        <div class=\"lido-contact-info__row\">\n          <div class=\"lido-contact-info__icon\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z\"/><path d=\"M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z\"/></svg>\n          </div>\n          <div>\n            <div class=\"lido-contact-info__label\">Orari assistenza</div>\n            <div class=\"lido-contact-info__value\">Lun–Ven: 9:00–18:00<br>Sab: 9:00–13:00</div>\n          </div>\n        </div>\n\n        <div class=\"lido-contact-info__row\">\n          <div class=\"lido-contact-info__icon\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" viewBox=\"0 0 16 16\"><path d=\"M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z\"/></svg>\n          </div>\n          <div>\n            <div class=\"lido-contact-info__label\">Spedizioni verso</div>\n            <div class=\"lido-contact-info__value\">Italia e tutta Europa<br><span style=\"font-size:0.8rem;color:#777;\">Consegna 3–5 giorni lavorativi</span></div>\n          </div>\n        </div>\n\n        <div style=\"margin-top:24px;padding:16px;background:rgba(232,130,12,0.08);border-radius:8px;border-left:3px solid #e8820c;\">\n          <p style=\"font-family:'Urbanist',sans-serif;font-size:0.82rem;color:#333;line-height:1.6;margin:0;\">\n            <strong style=\"color:#e8820c;\">Sei un rivenditore?</strong><br>\n            Contattaci per ottenere un listino prezzi all'ingrosso personalizzato e condizioni dedicate per il tuo business.\n          </p>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</div>"
      }
    }
  },
  "order": ["main"]
}
